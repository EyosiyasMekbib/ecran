{
  "kind": "collectionType",
  "collectionName": "resources",
  "info": {
    "singularName": "resource",
    "pluralName": "resources",
    "displayName": "Resource"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "resourceType": {
      "type": "enumeration",
      "enum": ["Annual report", "Policy brief", "Publication", "Toolkit", "Other"],
      "default": "Publication"
    },
    "summary": {
      "type": "text"
    },
    "document": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["files"]
    },
    "publishedOn": {
      "type": "date"
    }
  }
}
