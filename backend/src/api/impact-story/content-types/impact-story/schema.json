{
  "kind": "collectionType",
  "collectionName": "impact_stories",
  "info": {
    "singularName": "impact-story",
    "pluralName": "impact-stories",
    "displayName": "Impact Story"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "excerpt": {
      "type": "text",
      "required": true
    },
    "body": {
      "type": "richtext"
    },
    "publishedOn": {
      "type": "date"
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
